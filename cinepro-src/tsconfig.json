{
    "compilerOptions": {
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "target": "ES2022",
        "lib": ["ES2022"],
        "outDir": "../cinepro-dist",
        "rootDir": ".",
        "strict": false,
        "skipDefaultLibCheck": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": false,
        "sourceMap": false,
        "noEmit": false
    },
    "include": ["./**/*.ts"],
    "exclude": ["node_modules"]
}
