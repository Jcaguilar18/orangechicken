<%- include('partials/header') %>

<style>
  .payment-tabs {
    display: flex;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border);
    margin-bottom: 1.5rem;
  }
  .tab-btn {
    flex: 1;
    padding: 0.85rem 1rem;
    background: transparent;
    border: none;
    color: var(--muted);
    font-family: 'Orbitron', sans-serif;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }
  .tab-btn.active {
    background: rgba(0,212,255,0.12);
    color: var(--cyan);
  }
  .tab-btn:first-child { border-right: 1px solid var(--border); }
  .payment-panel { display: none; }
  .payment-panel.active { display: block; }
</style>

<div class="container">
  <section class="hero" style="padding-bottom:2rem">
    <div class="hero-glow"></div>
    <p class="hero-label">UPGRADE</p>
    <h1 class="hero-title">Go PRO</h1>
    <p class="hero-sub">Unlimited tool and scraper access — GCash ₱20/mo or PayPal $1/mo.</p>
  </section>

  <div class="glow-line"></div>

  <div style="max-width:560px;margin:2rem auto;display:flex;flex-direction:column;gap:1.5rem">

    <% if (isActive) { %>
      <div class="alert alert-success">
        ✅ You have an active PRO subscription! Expires: <strong><%= subscription.endDate %></strong>
      </div>
    <% } else if (subscription && subscription.status === 'pending') { %>
      <div class="alert" style="background:rgba(251,191,36,.1);border:1px solid rgba(251,191,36,.4);color:#fbbf24;border-radius:8px;padding:1rem">
        ⏳ Your subscription request is pending admin approval.
        <% if (subscription.paymentMethod === 'paypal') { %>
          PayPal transaction ID: <strong><%= subscription.gcashRef %></strong>
        <% } else { %>
          GCash ref: <strong><%= subscription.gcashRef %></strong>
        <% } %>
      </div>
    <% } %>

    <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
    <% if (error)   { %><div class="alert alert-error"><%= error %></div><% } %>

    <% if (!isActive) { %>

      <div class="glass-card">
        <h3 style="color:var(--cyan);font-family:'Orbitron',sans-serif;margin-bottom:1rem;font-size:1rem">PRO BENEFITS</h3>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:.6rem;font-size:.9rem;color:#ccc">
          <li>✦ Unlimited tool conversions (no 3/day cap)</li>
          <li>✦ Unlimited web scraper use</li>
          <li>✦ Full scraper settings — higher timeouts, larger files</li>
        </ul>
      </div>

      <div class="glass-card">
        <div class="payment-tabs">
          <button type="button" class="tab-btn active" data-tab="gcash">GCash &nbsp;₱20/mo</button>
          <button type="button" class="tab-btn" data-tab="paypal">PayPal &nbsp;$1/mo</button>
        </div>

        <form action="/subscribe" method="POST" id="subForm">
          <input type="hidden" name="paymentMethod" id="paymentMethod" value="gcash" />

          <!-- GCash panel -->
          <div class="payment-panel active" id="panel-gcash">
            <% if (qrImage || gcashNum) { %>
              <% if (qrImage) { %>
                <div style="text-align:center;margin-bottom:1.25rem">
                  <img src="/uploads/settings/<%= qrImage %>" alt="GCash QR Code"
                       style="max-width:200px;border-radius:12px;border:2px solid var(--cyan);display:inline-block" />
                  <p style="font-size:.8rem;color:var(--muted);margin-top:.5rem">Scan QR to pay via GCash</p>
                </div>
              <% } %>
              <% if (gcashNum) { %>
                <div style="background:rgba(0,212,255,.08);border:1px solid rgba(0,212,255,.3);border-radius:8px;padding:1rem;margin-bottom:1.25rem;text-align:center">
                  <p style="font-size:.8rem;color:var(--muted);margin-bottom:.25rem">GCash Number</p>
                  <p style="font-size:1.3rem;font-family:'Orbitron',sans-serif;color:var(--cyan);letter-spacing:2px"><%= gcashNum %></p>
                </div>
              <% } %>
            <% } else { %>
              <p style="color:var(--muted);text-align:center;margin-bottom:1.25rem">GCash payment info will be available soon.</p>
            <% } %>
            <div class="form-group">
              <label class="form-label">GCash Reference Number</label>
              <input type="text" name="gcashRef" class="form-input"
                     placeholder="e.g. 2024041200001234" autocomplete="off" />
            </div>
          </div>

          <!-- PayPal panel -->
          <div class="payment-panel" id="panel-paypal">
            <% if (paypalMe || paypalEmail) { %>
              <% if (paypalMe) { %>
                <div style="text-align:center;margin-bottom:1.25rem">
                  <a href="https://paypal.me/<%= paypalMe %>/1" target="_blank" rel="noopener"
                     class="btn btn-primary" style="display:inline-flex;align-items:center;gap:.6rem;font-size:1rem;padding:.85rem 2rem">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M7.076 21.337H2.47a.641.641 0 0 1-.633-.74L4.944.901C5.026.382 5.474 0 5.998 0h7.46c2.57 0 4.578.543 5.69 1.81 1.01 1.15 1.304 2.42 1.012 4.287-.023.143-.047.288-.077.437-.983 5.05-4.349 6.797-8.647 6.797h-2.19c-.524 0-.968.382-1.05.9l-1.12 7.106zm14.146-14.42a3.35 3.35 0 0 0-.607-.541c-.013.076-.026.175-.041.254-.93 4.778-4.005 7.201-9.138 7.201h-2.19a.563.563 0 0 0-.556.479l-1.187 7.527h-.506l-.24 1.516a.56.56 0 0 0 .554.647h3.882c.46 0 .85-.334.922-.788.06-.26.76-4.852.816-5.09a.932.932 0 0 1 .923-.788h.58c3.76 0 6.705-1.528 7.565-5.946.36-1.847.174-3.388-.777-4.471z"/>
                    </svg>
                    Pay $1 via PayPal.me
                  </a>
                </div>
              <% } %>
              <% if (paypalEmail) { %>
                <div style="background:rgba(0,212,255,.08);border:1px solid rgba(0,212,255,.3);border-radius:8px;padding:1rem;margin-bottom:1.25rem;text-align:center">
                  <p style="font-size:.8rem;color:var(--muted);margin-bottom:.25rem">Send $1 to</p>
                  <p style="font-size:1.05rem;color:var(--cyan)"><%= paypalEmail %></p>
                </div>
              <% } %>
            <% } else { %>
              <p style="color:var(--muted);text-align:center;margin-bottom:1.25rem">PayPal payment info will be available soon.</p>
            <% } %>
            <div class="form-group">
              <label class="form-label">PayPal Transaction ID</label>
              <input type="text" name="paypalRef" class="form-input"
                     placeholder="e.g. 5TY05013RG057411E" autocomplete="off" />
            </div>
          </div>

          <p style="font-size:.8rem;color:var(--muted);margin:1rem 0">
            Admin will verify and activate your subscription within 24 hours.
          </p>
          <button type="submit" class="btn btn-primary" style="width:100%">Submit →</button>
        </form>
      </div>
    <% } %>
  </div>
</div>

<script>
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.payment-panel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('panel-' + btn.dataset.tab).classList.add('active');
      document.getElementById('paymentMethod').value = btn.dataset.tab;
    });
  });
</script>

<%- include('partials/footer') %>
