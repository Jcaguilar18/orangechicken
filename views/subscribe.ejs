<%- include('partials/header') %>

<style>
  .payment-tabs {
    display: flex;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border);
    margin-bottom: 1.5rem;
  }
  .tab-btn {
    flex: 1;
    padding: 0.85rem 1rem;
    background: transparent;
    border: none;
    color: var(--muted);
    font-family: 'Orbitron', sans-serif;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }
  .tab-btn.active { background: rgba(0,212,255,0.12); color: var(--cyan); }
  .tab-btn:first-child { border-right: 1px solid var(--border); }
  .payment-panel { display: none; }
  .payment-panel.active { display: block; }

  .plan-options { display: flex; gap: .75rem; margin-bottom: 1.25rem; }
  .plan-option {
    flex: 1;
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: .85rem 1rem;
    cursor: pointer;
    transition: border-color .2s, background .2s;
    text-align: center;
  }
  .plan-option.selected {
    border-color: var(--cyan);
    background: rgba(0,212,255,.08);
  }
  .plan-option input { display: none; }
  .plan-price { font-family: 'Orbitron', sans-serif; font-size: 1.1rem; color: var(--cyan); }
  .plan-label { font-size: .78rem; color: var(--muted); margin-top: .2rem; }

  #paypal-btn-container { min-height: 50px; }
  .paypal-msg { color: var(--muted); font-size: .85rem; text-align: center; padding: 1rem 0; }
</style>

<div class="container">
  <section class="hero" style="padding-bottom:2rem">
    <div class="hero-glow"></div>
    <p class="hero-label">UPGRADE</p>
    <h1 class="hero-title">Go PRO</h1>
    <p class="hero-sub">Unlimited tools and scraper — GCash ₱20/mo or PayPal $1/mo · $5 lifetime.</p>
  </section>

  <div class="glow-line"></div>

  <div style="max-width:560px;margin:2rem auto;display:flex;flex-direction:column;gap:1.5rem">

    <% if (isActive) { %>
      <div class="alert alert-success">
        ✅ You have an active PRO subscription!
        <% if (subscription.plan === 'lifetime') { %>
          <strong>Lifetime</strong> — never expires.
        <% } else { %>
          Expires: <strong><%= subscription.endDate %></strong>
        <% } %>
      </div>
    <% } else if (subscription && subscription.status === 'pending') { %>
      <div class="alert" style="background:rgba(251,191,36,.1);border:1px solid rgba(251,191,36,.4);color:#fbbf24;border-radius:8px;padding:1rem">
        ⏳ Your subscription request is pending admin approval.
        GCash ref: <strong><%= subscription.gcashRef %></strong>
      </div>
    <% } %>

    <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
    <% if (error)   { %><div class="alert alert-error"><%= error %></div><% } %>

    <% if (!isActive) { %>

      <div class="glass-card">
        <h3 style="color:var(--cyan);font-family:'Orbitron',sans-serif;margin-bottom:1rem;font-size:1rem">PRO BENEFITS</h3>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:.6rem;font-size:.9rem;color:#ccc">
          <li>✦ Unlimited tool conversions — no 3/day cap</li>
          <li>✦ Unlimited web scraper use</li>
          <li>✦ Full scraper settings — higher timeouts, larger files</li>
        </ul>
      </div>

      <div class="glass-card">
        <div class="payment-tabs">
          <button type="button" class="tab-btn active" data-tab="gcash">GCash &nbsp;₱20/mo</button>
          <button type="button" class="tab-btn" data-tab="paypal">PayPal</button>
        </div>

        <!-- ── GCash panel ── -->
        <div class="payment-panel active" id="panel-gcash">
          <form action="/subscribe" method="POST">
            <input type="hidden" name="paymentMethod" value="gcash" />
            <% if (qrImage || gcashNum) { %>
              <% if (qrImage) { %>
                <div style="text-align:center;margin-bottom:1.25rem">
                  <img src="/uploads/settings/<%= qrImage %>" alt="GCash QR"
                       style="max-width:200px;border-radius:12px;border:2px solid var(--cyan);display:inline-block" />
                  <p style="font-size:.8rem;color:var(--muted);margin-top:.5rem">Scan to pay ₱20 via GCash</p>
                </div>
              <% } %>
              <% if (gcashNum) { %>
                <div style="background:rgba(0,212,255,.08);border:1px solid rgba(0,212,255,.3);border-radius:8px;padding:1rem;margin-bottom:1.25rem;text-align:center">
                  <p style="font-size:.8rem;color:var(--muted);margin-bottom:.25rem">GCash Number</p>
                  <p style="font-size:1.3rem;font-family:'Orbitron',sans-serif;color:var(--cyan);letter-spacing:2px"><%= gcashNum %></p>
                </div>
              <% } %>
            <% } else { %>
              <p style="color:var(--muted);text-align:center;margin-bottom:1.25rem">GCash payment info will be available soon.</p>
            <% } %>
            <div class="form-group">
              <label class="form-label">GCash Reference Number</label>
              <input type="text" name="gcashRef" class="form-input" placeholder="e.g. 2024041200001234" autocomplete="off" required />
            </div>
            <p style="font-size:.8rem;color:var(--muted);margin:.75rem 0">Admin will verify and activate within 24 hours.</p>
            <button type="submit" class="btn btn-primary" style="width:100%">Submit →</button>
          </form>
        </div>

        <!-- ── PayPal panel ── -->
        <div class="payment-panel" id="panel-paypal">
          <!-- Plan selector -->
          <div class="plan-options" id="planOptions">
            <label class="plan-option selected" id="opt-monthly">
              <input type="radio" name="paypalPlan" value="monthly" checked />
              <div class="plan-price">$1</div>
              <div class="plan-label">per month</div>
            </label>
            <label class="plan-option" id="opt-lifetime">
              <input type="radio" name="paypalPlan" value="lifetime" />
              <div class="plan-price">$5</div>
              <div class="plan-label">lifetime</div>
            </label>
          </div>

          <div class="paypal-msg" id="paypal-loading">Loading PayPal...</div>
          <!-- Separate containers — PayPal requires element to stay in DOM -->
          <div id="paypal-btn-monthly"></div>
          <div id="paypal-btn-lifetime" style="display:none"></div>
          <div id="paypal-error" style="display:none;color:#f87171;font-size:.85rem;margin-top:.75rem;text-align:center"></div>
        </div>
      </div>
    <% } %>
  </div>
</div>

<script>
  // Tab switching
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.payment-panel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('panel-' + btn.dataset.tab).classList.add('active');
      if (btn.dataset.tab === 'paypal') initPayPal();
    });
  });

  // Plan toggle — only swap visibility, never destroy rendered buttons
  document.querySelectorAll('.plan-option').forEach(opt => {
    opt.addEventListener('click', () => {
      document.querySelectorAll('.plan-option').forEach(o => o.classList.remove('selected'));
      opt.classList.add('selected');
      showPlanContainer(selectedPlan());
    });
  });

  let paypalConfig = null;
  let rendered = { monthly: false, lifetime: false };

  function selectedPlan() {
    return document.querySelector('input[name="paypalPlan"]:checked')?.value || 'monthly';
  }

  function showPayPalError(msg) {
    const el = document.getElementById('paypal-error');
    el.innerHTML = msg;
    el.style.display = 'block';
  }

  function showPlanContainer(plan) {
    document.getElementById('paypal-btn-monthly').style.display  = plan === 'monthly'  ? '' : 'none';
    document.getElementById('paypal-btn-lifetime').style.display = plan === 'lifetime' ? '' : 'none';
  }

  function loadSDK(clientId) {
    return new Promise((resolve, reject) => {
      if (window.paypal) { resolve(); return; }
      const s = document.createElement('script');
      s.src = `https://www.paypal.com/sdk/js?client-id=${clientId}&vault=true&currency=USD`;
      s.onload  = resolve;
      s.onerror = () => reject(new Error('Failed to load PayPal SDK.'));
      document.head.appendChild(s);
    });
  }

  async function initPayPal() {
    if (rendered.monthly && rendered.lifetime) { showPlanContainer(selectedPlan()); return; }

    const loadingEl = document.getElementById('paypal-loading');
    loadingEl.style.display = 'block';
    loadingEl.textContent = 'Loading PayPal...';
    document.getElementById('paypal-error').style.display = 'none';

    if (!paypalConfig) {
      const cfg = await fetch('/subscribe/paypal/config').then(r => r.json()).catch(() => null);
      if (!cfg?.ok) {
        loadingEl.textContent = cfg?.error || 'PayPal is not available right now.';
        return;
      }
      paypalConfig = cfg;
    }

    try {
      await loadSDK(paypalConfig.clientId);
    } catch (e) {
      loadingEl.textContent = e.message;
      return;
    }

    loadingEl.style.display = 'none';

    // Render both buttons into their own permanent containers
    if (!rendered.monthly) {
      rendered.monthly = true;
      document.getElementById('paypal-btn-monthly').style.display = '';
      try {
        await paypal.Buttons({
          style: { shape: 'rect', color: 'blue', layout: 'vertical', label: 'subscribe' },
          createSubscription: async () => {
            const res = await fetch('/subscribe/paypal/create-subscription-server', { method: 'POST' }).then(r => r.json());
            if (!res.ok) throw new Error(res.error || 'Failed to create subscription.');
            return res.subscriptionId;
          },
          onApprove: async (data) => {
            document.getElementById('paypal-btn-monthly').innerHTML = '<div class="paypal-msg">Activating...</div>';
            const res = await fetch('/subscribe/paypal/activate-subscription', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ subscriptionId: data.subscriptionID }),
            }).then(r => r.json()).catch(() => ({ ok: false, error: 'Network error.' }));
            res.ok ? location.reload() : showPayPalError(res.error || 'Activation failed.');
          },
          onError: () => showPayPalError('PayPal error. Please try again.'),
        }).render('#paypal-btn-monthly');
      } catch (e) {
        rendered.monthly = false;
        showPayPalError('Button error: ' + e.message);
        return;
      }
    }

    if (!rendered.lifetime) {
      rendered.lifetime = true;
      document.getElementById('paypal-btn-lifetime').style.display = 'none';
      try {
        await paypal.Buttons({
          style: { shape: 'rect', color: 'gold', layout: 'vertical', label: 'pay' },
          createOrder: async () => {
            const res = await fetch('/subscribe/paypal/create-order', { method: 'POST' }).then(r => r.json());
            if (!res.ok) throw new Error(res.error);
            return res.id;
          },
          onApprove: async (data) => {
            document.getElementById('paypal-btn-lifetime').innerHTML = '<div class="paypal-msg">Processing...</div>';
            const res = await fetch('/subscribe/paypal/capture-order', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ orderId: data.orderID }),
            }).then(r => r.json()).catch(() => ({ ok: false, error: 'Network error.' }));
            res.ok ? location.reload() : showPayPalError(res.error || 'Payment failed.');
          },
          onError: () => showPayPalError('PayPal error. Please try again.'),
        }).render('#paypal-btn-lifetime');
      } catch (e) {
        rendered.lifetime = false;
        showPayPalError('Button error: ' + e.message);
        return;
      }
    }

    showPlanContainer(selectedPlan());
  }
</script>

<%- include('partials/footer') %>
