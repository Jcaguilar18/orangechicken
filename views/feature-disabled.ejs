<%- include('partials/header') %>

<div style="min-height:60vh;display:flex;align-items:center;justify-content:center;padding:3rem 1.25rem;text-align:center">
  <div style="max-width:440px">
    <div style="font-size:3.5rem;margin-bottom:1.25rem"><%= reason === 'blocked' ? '🚫' : '🔒' %></div>
    <h1 style="font-size:1.6rem;font-weight:800;color:#fff;margin-bottom:.75rem">
      <%= reason === 'blocked' ? 'Access Restricted' : 'Feature Unavailable' %>
    </h1>
    <p style="color:#64748b;font-size:.95rem;line-height:1.6;margin-bottom:2rem">
      <% if (reason === 'blocked') { %>
        You don't have access to this feature. Contact the admin if you think this is a mistake.
      <% } else { %>
        This feature has been temporarily disabled. Check back later.
      <% } %>
    </p>
    <a href="/" class="btn btn-ghost">← Go Home</a>
  </div>
</div>

<%- include('partials/footer') %>
