<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : "Orange Chicken" %></title>
  <meta name="description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'Orange Chicken — a cozy community, portfolio, and free online tools.' %>" />
  <% if (typeof metaKeywords !== 'undefined') { %>
  <meta name="keywords" content="<%= metaKeywords %>" />
  <% } %>
  <meta property="og:title" content="<%= typeof pageTitle !== 'undefined' ? pageTitle : 'Orange Chicken' %>" />
  <meta property="og:description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'Orange Chicken — a cozy community, portfolio, and free online tools.' %>" />
  <meta property="og:type" content="website" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" href="/img/mascot.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Rye&family=Playfair+Display:ital,wght@0,600;0,700;1,600&family=Lora:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>" />
</head>
<body>
  <canvas id="spaceCanvas"></canvas>

  <nav class="navbar">
    <a href="/" class="brand">
      <img src="/img/mascot.png" class="brand-mascot" alt="Orange Chicken mascot" onerror="this.style.display='none'" />
      ORANGE CHICKEN
    </a>
    <button class="nav-toggle" id="navToggle" aria-label="Toggle menu">☰</button>
    <div class="nav-links" id="navLinks">
      <a href="/portfolio" class="btn btn-ghost">Portfolio</a>
      <a href="/tools" class="btn btn-ghost">Tools</a>
      <a href="/contact" class="btn btn-ghost">Contact</a>
      <% if (currentUser) { %>
        <a href="/users/<%= currentUser.username %>" class="nav-user nav-user-link">
          <% if (currentUser.avatar) { %>
            <img src="<%= currentUser.avatar %>" class="nav-avatar" alt="" />
          <% } else { %>
            <span class="user-dot"></span>
          <% } %>
          <%= currentUser.username %>
          <% if (isSubscriber) { %><span class="subscriber-badge">PRO</span><% } %>
        </a>
        <% if (currentUser.isAdmin) { %>
          <a href="/admin" class="btn btn-admin">⚙ Admin</a>
        <% } %>
        <a href="/articles/new" class="btn btn-primary">+ Post</a>
        <a href="/logout" class="btn btn-ghost">Log Out</a>
      <% } else { %>
        <a href="/login" class="btn btn-ghost">Log In</a>
        <a href="/register" class="btn btn-primary">Join the Coop</a>
      <% } %>
    </div>
  </nav>
  <script>
    (function () {
      var toggle = document.getElementById('navToggle');
      var links  = document.getElementById('navLinks');
      toggle.addEventListener('click', function () {
        links.classList.toggle('nav-open');
        toggle.textContent = links.classList.contains('nav-open') ? '✕' : '☰';
      });
      links.querySelectorAll('a').forEach(function (a) {
        a.addEventListener('click', function () {
          links.classList.remove('nav-open');
          toggle.textContent = '☰';
        });
      });
    })();
  </script>

  <% if (showProWelcome) { %>
  <div id="proWelcomeOverlay" role="dialog" aria-modal="true" aria-labelledby="proWelcomeTitle" style="
    position:fixed;inset:0;z-index:9999;
    background:rgba(0,0,0,.75);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);
    display:flex;align-items:center;justify-content:center;padding:1.5rem
  ">
    <div style="
      background:linear-gradient(135deg,#1a0e00 0%,#2b1800 100%);
      border:1px solid rgba(200,110,20,.5);
      border-radius:16px;max-width:420px;width:100%;
      padding:2.5rem 2rem;text-align:center;
      box-shadow:0 0 60px rgba(200,110,20,.2)
    ">
      <div style="font-size:3rem;margin-bottom:1rem">🐔</div>
      <h2 id="proWelcomeTitle" style="font-family:'Rye',serif;font-size:1.1rem;color:var(--amber);letter-spacing:.1em;margin-bottom:.75rem">
        PRO ACCESS GRANTED
      </h2>
      <p style="color:#e2e8f0;font-size:.95rem;line-height:1.6;margin-bottom:.5rem">
        Congratulations! You've received <strong style="color:var(--amber)">Pro access</strong>.
      </p>
      <p style="color:var(--text-muted);font-size:.82rem;margin-bottom:1.75rem">
        Active until <strong style="color:#fff"><%= proWelcomeEndDate || 'your subscription end date' %></strong> — enjoy unlimited tool usage and no daily cap.
      </p>
      <button
        onclick="document.getElementById('proWelcomeOverlay').remove()"
        class="btn btn-primary"
        style="width:100%;padding:.75rem"
        autofocus
      >
        Let's go 🍗
      </button>
    </div>
  </div>
  <script>
    (function () {
      function onKey(e) {
        if (e.key === 'Escape') {
          var el = document.getElementById('proWelcomeOverlay');
          if (el) el.remove();
          document.removeEventListener('keydown', onKey);
        }
      }
      document.addEventListener('keydown', onKey);
    })();
  </script>
  <% } %>

  <div class="page-wrap">

