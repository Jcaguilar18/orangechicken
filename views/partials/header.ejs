<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : "Jc's Space" %></title>
  <meta name="description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'JC\'s Space — a social platform, portfolio, and free online tools.' %>" />
  <% if (typeof metaKeywords !== 'undefined') { %>
  <meta name="keywords" content="<%= metaKeywords %>" />
  <% } %>
  <meta property="og:title" content="<%= typeof pageTitle !== 'undefined' ? pageTitle : 'Jc\'s Space' %>" />
  <meta property="og:description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'JC\'s Space — a social platform, portfolio, and free online tools.' %>" />
  <meta property="og:type" content="website" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>" />
</head>
<body>
  <canvas id="spaceCanvas"></canvas>

  <nav class="navbar">
    <a href="/" class="brand">
      <span class="brand-icon">✦</span> JC'S SPACE
    </a>
    <button class="nav-toggle" id="navToggle" aria-label="Toggle menu">☰</button>
    <div class="nav-links" id="navLinks">
      <a href="/portfolio" class="btn btn-ghost">Portfolio</a>
      <a href="/tools" class="btn btn-ghost">Tools</a>
      <a href="/contact" class="btn btn-ghost">Contact</a>
      <% if (currentUser) { %>
        <a href="/users/<%= currentUser.username %>" class="nav-user nav-user-link">
          <% if (currentUser.avatar) { %>
            <img src="<%= currentUser.avatar %>" class="nav-avatar" alt="" />
          <% } else { %>
            <span class="user-dot"></span>
          <% } %>
          <%= currentUser.username %>
          <% if (isSubscriber) { %><span class="subscriber-badge">PRO</span><% } %>
        </a>
        <% if (currentUser.isAdmin) { %>
          <a href="/admin" class="btn btn-admin">⚙ Admin</a>
        <% } %>
        <a href="/articles/new" class="btn btn-primary">+ Transmit</a>
        <a href="/logout" class="btn btn-ghost">Log Out</a>
      <% } else { %>
        <a href="/login" class="btn btn-ghost">Log In</a>
        <a href="/register" class="btn btn-primary">Join the Network</a>
      <% } %>
    </div>
  </nav>
  <script>
    (function () {
      var toggle = document.getElementById('navToggle');
      var links  = document.getElementById('navLinks');
      toggle.addEventListener('click', function () {
        links.classList.toggle('nav-open');
        toggle.textContent = links.classList.contains('nav-open') ? '✕' : '☰';
      });
      links.querySelectorAll('a').forEach(function (a) {
        a.addEventListener('click', function () {
          links.classList.remove('nav-open');
          toggle.textContent = '☰';
        });
      });
    })();
  </script>

  <div class="page-wrap">
