<%- include('partials/header') %>

  <div class="container">

    <!-- Hero -->
    <section class="hero">
      <div class="hero-glow"></div>
      <p class="hero-label">LIVE TRANSMISSION FEED</p>
      <h1 class="hero-title">Jc's Space</h1>
      <p class="hero-sub">An open community across the cosmos. Share your discoveries.</p>
      <div class="hero-stats">
        <div class="stat">
          <div class="stat-num"><%= articles.length %></div>
          <div class="stat-label">Transmissions</div>
        </div>
        <div class="stat-sep"></div>
        <div class="stat">
          <div class="stat-num"><%= totalUsers %></div>
          <div class="stat-label">Explorers</div>
        </div>
        <div class="stat-sep"></div>
        <div class="stat">
          <div class="stat-num">∞</div>
          <div class="stat-label">Possibilities</div>
        </div>
      </div>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-top:1rem">
        <% if (currentUser) { %>
          <a href="/articles/new" class="btn btn-primary btn-hero">+ New Transmission</a>
        <% } else { %>
          <a href="/register" class="btn btn-primary btn-hero">Join the Network</a>
        <% } %>
        <a href="/tools" class="btn btn-hero" style="background:rgba(124,58,237,.25);border:1px solid rgba(124,58,237,.5);color:#c084fc">⚙ Tools</a>
        <a href="/portfolio" class="btn btn-hero" style="background:rgba(0,212,255,.08);border:1px solid rgba(0,212,255,.3);color:var(--cyan)">🛸 Portfolio</a>
      </div>
    </section>

    <!-- Features -->
    <div class="features-grid">
      <a href="/" class="feature-card">
        <span class="feature-icon">📡</span>
        <span class="feature-title">Transmissions</span>
        <span class="feature-desc">Post articles and connect with other explorers in the community feed.</span>
      </a>
      <a href="/tools" class="feature-card">
        <span class="feature-icon">⚙</span>
        <span class="feature-title">Tools</span>
        <span class="feature-desc">PDF merge, image conversion, QR codes, Word/Excel/PPT and more — free to use.</span>
      </a>
      <a href="/portfolio" class="feature-card">
        <span class="feature-icon">🛸</span>
        <span class="feature-title">Portfolio</span>
        <span class="feature-desc">Browse JC's projects, designs, and past work.</span>
      </a>
      <a href="/contact" class="feature-card">
        <span class="feature-icon">📬</span>
        <span class="feature-title">Contact</span>
        <span class="feature-desc">Send a message, ask a question, or open a commission.</span>
      </a>
      <a href="/subscribe" class="feature-card">
        <span class="feature-icon">⭐</span>
        <span class="feature-title">Subscribe</span>
        <span class="feature-desc">Go PRO for ₱20/month — unlimited tool usage, no daily cap.</span>
      </a>
    </div>

    <div class="glow-line"></div>

    <!-- Feed -->
    <section class="feed">
      <div class="feed-header">
        <h2 class="feed-title">LATEST TRANSMISSIONS</h2>
      </div>

      <% if (articles.length === 0) { %>
        <div class="empty-state">
          <div class="empty-icon">🌌</div>
          <h3>The void awaits a signal.</h3>
          <p>Be the first to transmit a message into the cosmos.</p>
          <% if (currentUser) { %>
            <a href="/articles/new" class="btn btn-primary" style="margin-top:1.5rem">Start Transmitting</a>
          <% } %>
        </div>
      <% } else { %>
        <div class="article-grid">
          <% articles.forEach(article => { %>
            <div class="article-card-wrapper">
              <a href="/articles/<%= article.id %>" class="article-card">
                <div class="article-card-inner">
                  <% if (article.images && article.images.length > 0) { %>
                    <div class="article-card-img-wrap">
                      <img src="<%= article.images[0] %>" alt="" class="article-card-img" loading="lazy" />
                    </div>
                  <% } %>
                  <h3 class="article-title"><%= article.title %></h3>
                  <div class="article-meta">
                    <span class="meta-author">
                      <% if (article.author.avatar) { %>
                        <img src="<%= article.author.avatar %>" class="meta-avatar-xs" alt="" />
                      <% } %>
                      ✦ <%= article.author.username %>
                    </span>
                    <span class="meta-sep">·</span>
                    <span class="meta-date">
                      <%= new Date(article.createdAt).toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' }) %>
                    </span>
                    <% if (article.attachments && article.attachments.length > 0) { %>
                      <span class="attachment-badge">📎 <%= article.attachments.length %></span>
                    <% } %>
                  </div>
                  <p class="article-excerpt">
                    <%= article.content.length > 220 ? article.content.substring(0, 220) + '…' : article.content %>
                  </p>
                  <div class="article-footer-row">
                    <span class="read-more">Read transmission →</span>
                    <span class="comment-badge">
                      💬 <%= article.Comments ? article.Comments.length : 0 %>
                    </span>
                  </div>
                </div>
                <div class="card-glow"></div>
              </a>
              <% if (currentUser && currentUser.isAdmin) { %>
                <form
                  class="admin-delete-card"
                  action="/admin/articles/<%= article.id %>/delete"
                  method="POST"
                  onsubmit="return confirm('Delete this transmission permanently?')"
                >
                  <button type="submit" class="btn-delete-card" title="Delete article">✕</button>
                </form>
              <% } %>
            </div>
          <% }) %>
        </div>
      <% } %>
    </section>

  </div>

<%- include('partials/footer') %>
