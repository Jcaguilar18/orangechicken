<%- include('partials/header') %>

<div class="container">
  <section class="hero" style="padding-bottom:2rem">
    <p class="hero-label">ADMIN</p>
    <h1 class="hero-title" style="font-size:2rem">Popup Announcement</h1>
    <p class="hero-sub">Leave a message that appears to every visitor on page load.</p>
  </section>

  <div style="margin-bottom:2rem">
    <a href="/admin" class="btn btn-ghost">← Back to Admin</a>
  </div>

  <% if (success) { %><div class="alert alert-success" style="margin-bottom:1.5rem"><%= success %></div><% } %>
  <% if (error)   { %><div class="alert alert-error"   style="margin-bottom:1.5rem"><%= error %></div><% } %>

  <div class="glass-card" style="max-width:560px;margin:0 auto">
    <form action="/admin/popup" method="POST">

      <div class="form-group" style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem">
        <label class="form-label" style="margin:0">Show Popup</label>
        <label style="display:flex;align-items:center;gap:.6rem;cursor:pointer">
          <input type="checkbox" name="enabled" value="1" <%= popup.enabled ? 'checked' : '' %>
            style="width:18px;height:18px;accent-color:var(--cyan)" />
          <span style="font-size:.85rem;color:var(--muted)">Enabled</span>
        </label>
      </div>

      <div class="form-group">
        <label class="form-label">Title <span style="color:var(--muted);font-weight:400">(optional)</span></label>
        <input type="text" name="title" class="form-input" maxlength="100"
               placeholder="e.g. 🎉 Welcome!" value="<%= popup.title || '' %>" />
      </div>

      <div class="form-group">
        <label class="form-label">Message</label>
        <textarea name="message" class="form-input" rows="5" maxlength="500"
                  placeholder="Write your message here..."><%= popup.message || '' %></textarea>
        <p style="font-size:.75rem;color:var(--muted);margin-top:.25rem">Max 500 characters. Line breaks are preserved.</p>
      </div>

      <button type="submit" class="btn btn-primary" style="width:100%">Save Popup</button>
    </form>
  </div>

  <!-- Live preview -->
  <div style="max-width:560px;margin:2rem auto 0">
    <p style="font-size:.75rem;color:var(--muted);margin-bottom:.75rem;text-transform:uppercase;letter-spacing:.05em">Preview</p>
    <div style="background:#1a1a1a;border:1px solid var(--cyan);border-radius:14px;padding:1.2rem 1.2rem 1rem;position:relative;max-width:320px">
      <button disabled style="position:absolute;top:.6rem;right:.75rem;background:none;border:none;color:#666;font-size:1.1rem;line-height:1">✕</button>
      <p id="previewTitle" style="font-family:'Rye',serif;font-size:.85rem;color:var(--cyan);letter-spacing:.05em;margin:0 0 .5rem"></p>
      <p id="previewMsg"   style="font-size:.85rem;color:#ccc;line-height:1.55;margin:0;white-space:pre-wrap"></p>
    </div>
  </div>
</div>

<script>
  const titleIn = document.querySelector('[name="title"]');
  const msgIn   = document.querySelector('[name="message"]');
  const prevT   = document.getElementById('previewTitle');
  const prevM   = document.getElementById('previewMsg');

  function syncPreview() {
    prevT.textContent = titleIn.value;
    prevT.style.display = titleIn.value ? '' : 'none';
    prevM.textContent = msgIn.value;
  }
  titleIn.addEventListener('input', syncPreview);
  msgIn.addEventListener('input', syncPreview);
  syncPreview();
</script>

<%- include('partials/footer') %>
