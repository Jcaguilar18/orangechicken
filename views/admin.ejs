<%- include('partials/header') %>

  <div class="container">
    <div class="admin-header">
      <div>
        <p class="hero-label">COMMAND CENTER</p>
        <h1 class="page-title" style="font-size:2rem;margin-bottom:0.25rem">Admin Panel</h1>
        <p class="page-sub"><%= users.length %> registered explorer<%= users.length !== 1 ? 's' : '' %> in the network</p>
      </div>
      <a href="/" class="btn btn-ghost">← Back to Feed</a>
    </div>

    <% if (success) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } %>
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <!-- Quick links -->
    <div style="display:flex;gap:1rem;flex-wrap:wrap;margin-bottom:2rem">
      <a href="/admin/portfolio" class="btn btn-ghost">🛸 Portfolio</a>
      <a href="/admin/messages" class="btn btn-ghost">📬 Messages</a>
      <a href="/admin/subscriptions" class="btn btn-ghost">💳 Subscriptions</a>
      <a href="/admin/settings" class="btn btn-ghost">⚙ GCash Settings</a>
      <a href="/admin/scraper" class="btn btn-ghost">🕷 Web Scraper</a>
      <a href="/admin/shows" class="btn btn-ghost">🎬 Shows</a>
      <a href="#tools-settings" class="btn btn-ghost">🆓 Tools Settings</a>
      <a href="#exclusive-settings" class="btn btn-ghost">👑 Exclusive Access</a>
      <a href="/admin/features" class="btn btn-ghost">🔒 Feature Visibility</a>
      <a href="/admin/popup" class="btn btn-ghost">📢 Popup Announcement</a>
    </div>

    <div class="glow-line"></div>

    <!-- Tools Settings -->
    <section class="admin-section" id="tools-settings" style="margin-bottom:2.5rem">
      <h2 class="feed-title" style="margin-bottom:1.5rem">TOOLS SETTINGS</h2>
      <div class="glass-card" style="max-width:520px">
        <form action="/admin/tools-settings" method="POST">

          <div style="display:flex;align-items:center;justify-content:space-between;gap:1.5rem;margin-bottom:1.75rem">
            <div>
              <div style="font-weight:600;color:#fff;margin-bottom:.25rem">Free Mode</div>
              <div style="font-size:.82rem;color:var(--muted)">Remove all limits — everyone gets unlimited access. Show "Free Tools" banner on the tools page.</div>
            </div>
            <label class="oc-toggle" title="Toggle Free Mode">
              <input type="checkbox" name="freeMode" value="1" <%= toolsFreeMode ? 'checked' : '' %> onchange="this.form.submit()">
              <span class="oc-toggle-track">
                <span class="oc-toggle-thumb"></span>
              </span>
            </label>
          </div>

          <div class="form-group" style="margin-bottom:1.5rem">
            <label class="form-label">Daily Limit per User</label>
            <div style="display:flex;align-items:center;gap:.75rem">
              <input type="number" name="dailyLimit" class="form-input" value="<%= toolsDailyLimit %>"
                     min="1" max="999" style="max-width:90px;text-align:center" />
              <span style="font-size:.85rem;color:var(--muted)">uses / day</span>
            </div>
            <p style="font-size:.8rem;color:var(--muted);margin-top:.35rem">Applied when Free Mode is off. Default: 3.</p>
          </div>

          <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap">
            <button type="submit" class="btn btn-primary">Save Settings</button>
            <% if (toolsFreeMode) { %>
              <span style="color:#fbbf24;font-size:.85rem;font-weight:600">🆓 Free Mode is ON</span>
            <% } else { %>
              <span style="color:var(--muted);font-size:.82rem">Limit: <%= toolsDailyLimit %> uses/day</span>
            <% } %>
          </div>
        </form>
      </div>
    </section>

    <style>
      .oc-toggle { position:relative;display:inline-flex;cursor:pointer;flex-shrink:0 }
      .oc-toggle input { position:absolute;opacity:0;width:0;height:0 }
      .oc-toggle-track {
        width:52px;height:28px;border-radius:28px;
        background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);
        transition:background .25s,border-color .25s;position:relative
      }
      .oc-toggle-thumb {
        position:absolute;top:3px;left:3px;width:20px;height:20px;border-radius:50%;
        background:#94a3b8;transition:transform .25s,background .25s
      }
      .oc-toggle input:checked ~ .oc-toggle-track { background:rgba(251,191,36,.25);border-color:#fbbf24 }
      .oc-toggle input:checked ~ .oc-toggle-track .oc-toggle-thumb { transform:translateX(24px);background:#fbbf24 }
    </style>

    <div class="glow-line"></div>

    <!-- Exclusive Access -->
    <section class="admin-section" id="exclusive-settings" style="margin-bottom:2.5rem">
      <h2 class="feed-title" style="margin-bottom:1.5rem">EXCLUSIVE ACCESS</h2>
      <div class="glass-card" style="max-width:520px">
        <form action="/admin/exclusive-access" method="POST">
          <p style="font-size:.85rem;color:var(--muted);margin-bottom:1.25rem">
            Control who can view the 👑 Exclusive player page.
          </p>
          <div style="display:flex;flex-direction:column;gap:.6rem;margin-bottom:1.5rem">
            <%
              const exModes = [
                { value:'all',         dot:'#22c55e', label:'Everyone',        desc:'Anyone, including guests' },
                { value:'logged_in',   dot:'#60a5fa', label:'Users only',      desc:'Must be logged in' },
                { value:'subscribers', dot:'#c084fc', label:'Pro subscribers', desc:'Active Pro or Pro VIP' },
                { value:'provip',      dot:'#facc15', label:'Pro VIP only',    desc:'Pro VIP badge required' },
                { value:'disabled',    dot:'#f87171', label:'Disabled',        desc:'Hidden for everyone' },
              ];
            %>
            <% exModes.forEach(opt => { %>
            <label style="display:flex;align-items:center;gap:.75rem;cursor:pointer;padding:.55rem .75rem;border-radius:10px;border:1px solid rgba(255,255,255,<%= exclusiveMode === opt.value ? '.15' : '.06' %>);background:rgba(255,255,255,<%= exclusiveMode === opt.value ? '.06' : '.02' %>);transition:all .15s">
              <input type="radio" name="mode" value="<%= opt.value %>"
                     <%= exclusiveMode === opt.value ? 'checked' : '' %>
                     style="accent-color:<%= opt.dot %>;width:15px;height:15px;flex-shrink:0" />
              <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:<%= opt.dot %>;flex-shrink:0"></span>
              <span style="flex:1">
                <span style="font-size:.88rem;font-weight:600;color:#e2e8f0"><%= opt.label %></span>
                <span style="font-size:.78rem;color:#64748b;margin-left:.4rem"><%= opt.desc %></span>
              </span>
            </label>
            <% }); %>
          </div>
          <button type="submit" class="btn btn-primary">Save</button>
        </form>
      </div>
    </section>

    <div class="glow-line"></div>

    <section class="admin-section">
      <h2 class="feed-title" style="margin-bottom:1.5rem">EXPLORER REGISTRY</h2>

      <div class="user-list">
        <% users.forEach(user => { %>
          <div class="user-card glass-card"
               style="<%= user.isBanned ? 'border-color:rgba(255,100,100,.4);background:rgba(255,30,30,.05)' : user.isRestricted ? 'border-color:rgba(255,160,0,.35);background:rgba(255,160,0,.03)' : '' %>">
            <div class="user-card-main">

              <!-- Avatar + Identity -->
              <div class="user-identity">
                <% if (user.avatar) { %>
                  <img src="<%= user.avatar %>" class="user-avatar-img" alt="<%= user.username %>" />
                <% } else { %>
                  <div class="user-avatar <%= user.isAdmin ? 'user-avatar--admin' : '' %>"
                       style="<%= user.isBanned ? 'background:rgba(255,100,100,.25);border-color:rgba(255,100,100,.5)' : '' %>">
                    <%= user.username.charAt(0).toUpperCase() %>
                  </div>
                <% } %>
                <div class="user-info">
                  <div class="user-name">
                    <a href="/users/<%= user.username %>" class="user-profile-link"><%= user.username %></a>
                    <% if (user.isAdmin) { %>
                      <span class="admin-badge">ADMIN</span>
                    <% } %>
                    <% if (user.isBanned) { %>
                      <span class="status-badge status-badge--banned">BANNED</span>
                    <% } %>
                    <% if (user.isRestricted) { %>
                      <span class="status-badge status-badge--restricted">RESTRICTED</span>
                    <% } %>
                    <% if (user.isProVIP) { %>
                      <span style="font-size:.65rem;font-weight:800;padding:.15rem .5rem;border-radius:20px;background:linear-gradient(135deg,#b45309,#f59e0b);color:#fff;letter-spacing:.06em">👑 PRO VIP</span>
                    <% } %>
                  </div>
                  <div class="user-email"><%= user.email %></div>
                  <div class="user-joined">
                    Joined <%= new Date(user.createdAt).toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' }) %>
                  </div>
                </div>
              </div>

              <!-- Stats -->
              <div class="user-stats">
                <div class="user-stat">
                  <div class="user-stat-num"><%= user.articleCount %></div>
                  <div class="user-stat-label">Articles</div>
                </div>
                <div class="user-stat">
                  <div class="user-stat-num"><%= user.commentCount %></div>
                  <div class="user-stat-label">Comments</div>
                </div>
              </div>

              <!-- Actions -->
              <% if (!user.isAdmin) { %>
                <div class="admin-user-actions">
                  <!-- Change password -->
                  <button class="btn btn-ghost btn-sm" onclick="togglePwForm('<%= user.id %>')">
                    🔑 Password
                  </button>

                  <!-- Ban / Unban -->
                  <% if (!user.isBanned) { %>
                    <form action="/admin/users/<%= user.id %>/ban" method="POST"
                          onsubmit="return confirm('Ban <%= user.username %>? They will be locked out immediately.')">
                      <button type="submit" class="btn btn-sm btn-warn">⊘ Ban</button>
                    </form>
                  <% } else { %>
                    <form action="/admin/users/<%= user.id %>/unban" method="POST">
                      <button type="submit" class="btn btn-sm btn-cyan">✓ Unban</button>
                    </form>
                  <% } %>

                  <!-- Restrict / Unrestrict -->
                  <% if (!user.isRestricted) { %>
                    <form action="/admin/users/<%= user.id %>/restrict" method="POST"
                          onsubmit="return confirm('Restrict <%= user.username %>? They can log in but cannot post or comment.')">
                      <button type="submit" class="btn btn-sm btn-orange">🚫 Restrict</button>
                    </form>
                  <% } else { %>
                    <form action="/admin/users/<%= user.id %>/unrestrict" method="POST">
                      <button type="submit" class="btn btn-sm btn-cyan">↑ Lift Restriction</button>
                    </form>
                  <% } %>

                  <!-- Pro VIP -->
                  <% if (!user.isProVIP) { %>
                    <form action="/admin/users/<%= user.id %>/provip" method="POST">
                      <button type="submit" class="btn btn-sm" style="background:linear-gradient(135deg,#b45309,#f59e0b);color:#fff;font-weight:700">👑 Grant VIP</button>
                    </form>
                  <% } else { %>
                    <form action="/admin/users/<%= user.id %>/unprovip" method="POST">
                      <button type="submit" class="btn btn-sm btn-ghost" style="border-color:#b45309;color:#f59e0b">↩ Revoke VIP</button>
                    </form>
                  <% } %>

                  <!-- Delete -->
                  <form action="/admin/users/<%= user.id %>/delete" method="POST"
                        onsubmit="return confirm('Permanently delete <%= user.username %>? This removes their account, articles, and comments. This CANNOT be undone.')">
                    <button type="submit" class="btn btn-sm btn-danger">🗑 Delete</button>
                  </form>
                </div>
              <% } else { %>
                <div class="admin-user-actions">
                  <button class="btn btn-ghost btn-sm" onclick="togglePwForm('<%= user.id %>')">
                    🔑 Password
                  </button>
                  <span style="font-size:.75rem;color:#64748b;padding:.25rem .5rem">Protected account</span>
                </div>
              <% } %>
            </div>

            <!-- Inline password form -->
            <div class="pw-form-wrap" id="pw-form-<%= user.id %>" style="display:none">
              <form action="/admin/users/<%= user.id %>/password" method="POST" class="pw-form">
                <div class="pw-form-inner">
                  <input
                    type="password"
                    name="newPassword"
                    class="form-input pw-input"
                    placeholder="New password (min 6 chars)"
                    minlength="6"
                    required
                    autocomplete="new-password"
                  />
                  <button type="submit" class="btn btn-primary btn-sm">Set Password</button>
                  <button type="button" class="btn btn-ghost btn-sm" onclick="togglePwForm('<%= user.id %>')">Cancel</button>
                </div>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    </section>
  </div>

  <script>
    function togglePwForm(userId) {
      const form = document.getElementById('pw-form-' + userId);
      const isHidden = form.style.display === 'none';
      form.style.display = isHidden ? 'block' : 'none';
      if (isHidden) form.querySelector('input').focus();
    }
  </script>

<%- include('partials/footer') %>
